# REQUIRED
PORT=4004
NODE_ENV=development

# DATABASE
DB_HOST=localhost
DB_PORT=5434
DB_USER=postgres
DB_PASS=postgres
DB_NAME=payments_db

# jwt
CORS_ORIGINS=*
JWT_SECRET=jwt-secret
JWT_EXPIRES_IN=24h

# services
USERS_SERVICE_URL=http://localhost:4001
PRODUCTS_SERVICE_URL=http://localhost:4002
CHECKOUT_SERVICE_URL=http://localhost:4003

# RabbitMQ
RABBITMQ_URL=amqp://admin:admin@localhost:5672
RABBITMQ_QUEUE_PAYMENTS=payments_queue
RABBITMQ_EXCHANGE=payments

# Payment Gateway
PAYMENT_GATEWAY_URL=
PAYMENT_GATEWAY_API_KEY=